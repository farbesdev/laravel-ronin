{
    "name": "farbesdev/laravel-ronin",
    "version": "1.0.0",
    "description": "Un paquete simple y flexible para la gestión de roles y permisos en Laravel. Controla el acceso a rutas y vistas de forma eficiente mediante un sistema basado en ACL.",
    "keywords": [
        "ronin",
        "roles",
        "permissions",
        "auth",
        "laravel",
        "laravel-ronin"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Fredy Rojas",
            "email": "farojas851@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Ronin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ronin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ronin\\ShinobiServiceProvider"
            ],
            "aliases": {
                "Shinobi": "Ronin\\Facades\\Shinobi"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "doctrine/dbal": "^3.0",
        "larastan/larastan": "^3.10",
        "laravel/legacy-factories": "^1.0@dev",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/php-code-coverage": "^14.1.10",
        "phpunit/phpunit": "^11.0|^12.0|^13.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --level=8",
        "ci": [
            "@test",
            "@analyse"
        ]
    },
    "scripts-descriptions": {
        "test": "Ejecuta la suite de pruebas PHPUnit",
        "analyse": "Ejecuta análisis estático con Larastan nivel 8",
        "ci": "Ejecuta tests + análisis estático (pipeline CI)"
    }
}